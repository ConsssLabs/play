# Node deps for the bridge build
bridge/node_modules/

# Built bridge bundle — a build artifact (esbuild), rebuilt by deploy.sh, not
# source. No secrets are baked in: the Tatum key lives in the /rpc edge Function.
public/dist/

# Never commit a secret config if one is copied in by mistake
**/config.local.js

# Wrangler local state/cache (may hold deploy state); never commit
.wrangler/

# Large engine binaries live as GitHub Release assets, never in git
# (GitHub rejects >100 MB; the .pck is ~128 MB after lossy-WebP optimization).
*.wasm
*.pck

# OS / editor cruft
.DS_Store
*.swp

# root deps (for Pages Functions bundling)
/node_modules/
